#!/usr/bin/env bash
# =============================================================================
#  /etc/nixos/scripts/nixos-rebuild   (no .sh — looks like a real binary)
#
#  Intercepts every call to `nixos-rebuild` that goes through sudo's
#  secure_path (see modules/rebuild-error-hook.nix).
#
#  Calls the REAL nixos-rebuild by full store path, pipes all output
#  through the error listener, and preserves the original exit code.
#  Nothing in nix/nixos-rebuild itself is modified.
#
#  Flow when invoked by nixorcist:
#    nixorcist
#      → lock.sh:run_rebuild
#      → nix-rebuild-smart.sh: sudo nixos-rebuild switch --upgrade ...
#      → sudo resolves nixos-rebuild → /etc/nixos/scripts/nixos-rebuild (HERE)
#      → /run/current-system/sw/bin/nixos-rebuild (real binary)
#          |— stdout+stderr → nixos-rebuild-error-listener.sh → stdout
# =============================================================================

REAL=/run/current-system/sw/bin/nixos-rebuild
LISTENER=/etc/nixos/scripts/nixos-rebuild-error-listener.sh

if [[ ! -x "$REAL" ]]; then
    echo "nixos-rebuild wrapper: real binary not found at $REAL" >&2
    exit 127
fi

if [[ ! -x "$LISTENER" ]]; then
    # Listener missing — fall back to running rebuild unmodified
    echo "nixos-rebuild wrapper: listener not found, running unhooked" >&2
    exec "$REAL" "$@"
fi

# Export context for the listener's log header
export NIXOS_REBUILD_CMD="nixos-rebuild $*"

# Capture real nixos-rebuild's exit code while piping through listener.
# The listener passes everything to stdout, so the caller (e.g. tee in
# nix-rebuild-smart.sh) still receives the full unmodified output stream.
EXIT_FILE=$(mktemp)

{
    "$REAL" "$@" 2>&1
    printf '%s' "$?" > "$EXIT_FILE"
} | "$LISTENER"

EXIT_CODE=$(cat "$EXIT_FILE" 2>/dev/null || echo 0)
rm -f "$EXIT_FILE"
exit "$EXIT_CODE"
